{
  "_comment": "LoreLake configuration. Defaults shown here apply when a key is omitted from the project's config.json.",
  "_schemaVersion": 1,

  "llake": {
    "_comment": "LoreLake-wide constants.",
    "fixedCategories": ["discussions", "decisions", "gotchas", "playbook"]
  },

  "sessionCapture": {
    "_comment": "Two-pass session capture: cheap triage → full capture on CAPTURE/PARTIAL.",
    "enabled": true,
    "triageModel": "sonnet",
    "triageEffort": "high",
    "triageBudgetUsd": 0.50,
    "captureModel": "sonnet",
    "captureEffort": "high",
    "maxBudgetUsd": 5.00,
    "timeoutSeconds": 600,
    "minTurns": 2,
    "minWords": 150,
    "allowedTools": ["Read", "Write", "Edit", "Glob", "Grep", "Bash"],
    "writableCategories": ["discussions", "decisions", "gotchas", "playbook"],
    "lockStalenessSeconds": 900
  },

  "ingest": {
    "_comment": "Post-merge agent that updates wiki from code changes on the monitored branch.",
    "enabled": true,
    "pipeline": "legacy",
    "model": "opus",
    "effort": "high",
    "maxBudgetUsd": 10.00,
    "timeoutSeconds": 1200,
    "branch": "main",
    "include": ["src/"],
    "allowedTools": ["Read", "Write", "Edit", "Glob", "Grep", "Bash"],
    "v2": {
      "_comment": "Settings for ingest pipeline v2 (planner + Python applier + fixer).",
      "plannerModel": "opus",
      "plannerEffort": "high",
      "plannerBudgetUsd": 5.00,
      "plannerAllowedTools": ["Read", "Glob", "Grep"],
      "fixerModel": "opus",
      "fixerEffort": "medium",
      "fixerBudgetUsd": 2.00,
      "fixerAllowedTools": ["Read", "Glob", "Grep"],
      "maxFixerRetries": 1,
      "diffChunkBytes": 2000,
      "timeoutSeconds": 1200,
      "contextBuild": {
        "_comment": "Tunables for the deterministic file-churn / forced-read computation in build_ingest_context.py.",
        "paretoTarget": 0.80,
        "maxFiles": 0,
        "maxBytes": 150000,
        "maxBytesPerFile": 30000,
        "multiTouchFloor": 3
      }
    }
  },

  "lint": {
    "_comment": "On-demand `/llake-lint` skill. Quick mode runs in-session and inherits the parent session's model/limits; these knobs apply only to Comprehensive-mode subagents and to the no-arg recommendation heuristic.",
    "model": "sonnet",
    "effort": "high",
    "comprehensive-recommended-after-days": 14,
    "comprehensive-recommended-after-activity": 20,
    "stale-threshold-days": 30
  },

  "transcript": {
    "_comment": "Transcript extraction & sampling.",
    "maxMessageLength": 2000,
    "headSize": 10,
    "tailSize": 20,
    "middleMaxSize": 30,
    "middleScaleStart": 100
  },

  "logging": {
    "_comment": "Hook log rotation for llake/.state/hooks.log.",
    "maxLines": 1000,
    "rotateKeepLines": 500
  },

  "prompts": {
    "_comment": "Per-prompt custom slot overrides. Empty/missing → template falls back to shipped defaults.",
    "ingest": {
      "EXAMPLES": ""
    }
  }
}
